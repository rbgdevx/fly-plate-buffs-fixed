{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime.version": "Lua 5.1",
  "runtime.nonstandardSymbol": [
    "!=",
    "continue",
    "//"
  ],
  "workspace.ignoreDir": [
    ".git",
    ".vscode",
    ".claude",
    "libs/AceConfig-3.0",
    "libs/AceDB-3.0",
    "libs/AceDBOptions-3.0",
    "libs/AceGUI-3.0",
    "libs/AceGUI-3.0-SharedMediaWidgets",
    "libs/CallbackHandler-1.0",
    "libs/LibSharedMedia-3.0",
    "libs/LibStub"
  ],
  "diagnostics.workspaceDelay": 3000,
  "diagnostics.disable": [
    "lowercase-global",
    "duplicate-set-field",
    "missing-fields",
    "inject-field",
    "cast-local-type",
    "param-type-mismatch",
    "return-type-mismatch"
  ],
  "diagnostics.globals": [
    "flyPlateBuffsFixed",
    "flyPlateBuffsFixedDB",
    "LibStub",
    "hooksecurefunc",
    "Mixin",
    "CopyTable",
    "MergeTable",
    "tContains",
    "CreateFromMixins",
    "CreateFrame",
    "CreateObjectPool",
    "BackdropTemplateMixin",
    "PixelUtil",
    "GenerateClosure",
    "WOW_PROJECT_ID",
    "WOW_PROJECT_MAINLINE",
    "WOW_PROJECT_CLASSIC",
    "SlashCmdList",
    "EventRegistry",
    "STANDARD_TEXT_FONT",
    "UIParent",
    "DEFAULT_CHAT_FRAME",
    "SOUNDKIT",
    "GameFontNormal",
    "GameFontHighlight",
    "GameFontHighlightSmall",
    "NORMAL_FONT_COLOR",
    "CUSTOM_CLASS_COLORS",
    "RAID_CLASS_COLORS",
    "DebuffTypeColor",
    "SetDesaturation",
    "ColorPickerFrame",
    "GameTooltip",
    "GetAppropriateTooltip",
    "C_NamePlate",
    "GetNamePlateForUnit",
    "AuraUtil",
    "C_UnitAuras",
    "GetCVar",
    "GetCVarBool",
    "SetCVar",
    "Settings",
    "Item",
    "format",
    "strsplit",
    "strmatch",
    "wipe"
  ],
  "completion.callSnippet": "Replace",
  "completion.keywordSnippet": "Replace",
  "hint.enable": true,
  "hint.setType": true,
  "semantic.enable": true,
  "telemetry.enable": false
}
